# Core app database (SQLite for local development)
DATABASE_URL=file:./dev.db

# LLM configuration (set at least one key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

LITELLM_API_KEY=
LITELLM_BASE_URL=
LITELLM_API_BASE=
LITELLM_PROXY_URL=
LITELLM_MODEL=openai/gemini-2.5-flash
MESH_MODEL_ID=openai/gemini-2.5-flash

# Semantic layer and local harness settings
SEMANTIC_DATABASE_URL=postgres://postgres:postgres@localhost:5432/semantic_layer_dev
SDET_URL=postgres://user@localhost:5432/entrata_sdet_1
SEMANTIC_TENANT_ID=00000000-0000-0000-0000-000000000001

# Fast Pass mapping controls
MAP_MEMORY_ENABLED=true
MAP_MEMORY_PRIORITY_BOOST=3
MAP_MEMORY_OVERRIDE_THRESHOLD=8

MAP_AGENT_ENABLED=true
MAP_AGENT_SHADOW_MODE=false
MAP_AGENT_AUTO_LEARN_ENABLED=true
MAP_AGENT_AUTO_LEARN_MIN_CONFIDENCE=95

MAP_LLM_RERANK_ENABLED=true
MAP_LLM_ONLY_FOR_LOW_CONFIDENCE=true
MAP_LLM_LOW_CONFIDENCE_THRESHOLD=85
MAP_LLM_AMBIGUITY_GAP_THRESHOLD=5

MAP_ASYNC_UNMATCHED_AGENT_ENABLED=true
MAP_ASYNC_UNMATCHED_THRESHOLD=70

# Memory ingestion controls
MEMORY_INGEST_MODE=rows
MEMORY_MIN_GUESS_SCORE=0.6
BUNDLE_DATASET=full
